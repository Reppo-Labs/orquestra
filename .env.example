# Wallet that holds REPPO. Use a DEDICATED wallet, never your main one.
# Plaintext at rest — bounded by the budget caps in strategy.config.json.
REPPO_PRIVATE_KEY=

# Reppo platform agent id, required to MINT pods (reppo >=0.8.0). OPTIONAL here:
# if minting is enabled and this is unset, the node auto-registers an agent on first
# run (`reppo register-agent`) and persists it to <data>/agent.json — set it explicitly
# only to reuse an existing agent identity.
# REPPO_AGENT_ID=

# Pinata IPFS JWT — needed only to MINT in the default "pin" mode (reppo pins each
# pod's dataset to IPFS via Pinata). NOT needed if you only vote, or if every minted
# datanet uses mintMode "url-only" (registers the source link, no pinning — set per
# datanet in the dashboard). Get one at https://pinata.cloud (free tier works).
# PINATA_JWT=

# Model-agnostic LLM. Set provider + that provider's key.
# provider: anthropic | openai | google | surplus | virtuals
#   surplus = Surplus Intelligence (https://surplusintelligence.ai), an
#   OpenAI-compatible discounted-inference marketplace. Its API keys are
#   prefixed `inf_`; default model is claude-opus-4.8.
#   virtuals = Virtuals inference gateway (https://compute.virtuals.io), an
#   OpenAI-compatible endpoint (Bearer key) settled via the Agent Commerce
#   Protocol (no per-call USDC). Keys are prefixed `acp-`; default model
#   claude-opus-4-8 (list models at GET /v1/models).
LLM_PROVIDER=virtuals
LLM_API_KEY=acp-your-virtuals-key
# Onboarding is an LLM chat — an LLM key is REQUIRED to configure the node.

# Optional MULTI-PROVIDER keys for per-datanet model selection (dashboard → datanet
# "vote model"). Set a provider's key here to make it selectable per datanet. These are
# ADDITIVE to LLM_PROVIDER/LLM_API_KEY above (which still sets the node default). Keys
# are read from the environment ONLY — never entered in or returned by the dashboard.
# A google key is REQUIRED to score video pods (only Gemini watches video natively).
# LLM_KEY_ANTHROPIC=sk-ant-...
# LLM_KEY_OPENAI=sk-...
# LLM_KEY_GOOGLE=AIza...
# LLM_KEY_VIRTUALS=acp-...
# LLM_KEY_SURPLUS=inf_...

# Where strategy.config.json + ledgers live (mounted volume in Docker).
ORQUESTRA_DATA_DIR=./data

# Optional private Base RPC. The public default (https://mainnet.base.org) rate-limits
# under a full cycle of per-datanet queries, causing INTERNAL_ERROR skips. Set this to
# a private endpoint (Alchemy/QuickNode/Ankr/...) and every reppo CLI call uses it.
# Also makes the mintReppoMax budget cap EXACT: the reppo CLI omits the mint fee, so
# the node reads it from the tx receipt via this RPC. Without RPC_URL the cap is STILL
# enforced, but the node conservatively assumes the max observed fee (~200 REPPO) per
# mint — set RPC_URL if you want the cap to track the real (often lower) fee.
# RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Dashboard served inside the container — read + configure (onboarding, strategy).
# Unauthenticated by design; docker-compose.yml binds it to 127.0.0.1 only, reach it
# over an SSH tunnel (see README / ADR 0002). Do not expose the port without auth.
# NOTE: the Docker HEALTHCHECK probes the dashboard's /api/health, so DASHBOARD_ENABLED=false
# makes `docker ps` report the container "unhealthy" even though the node runs fine
# (the scheduler is independent). Leave it true unless you don't need the health signal.
DASHBOARD_ENABLED=true
DASHBOARD_PORT=7070
# Interface the dashboard binds to. Defaults to 127.0.0.1 (loopback) so a bare
# `node`/`docker run` never exposes the unauthenticated panel to the network.
# Under the provided docker-compose.yml this is set to 0.0.0.0 IN THE COMPOSE FILE
# (it overrides this .env value) because the compose 127.0.0.1:7070:7070 host mapping is
# the real boundary — so you don't need to set it here for the standard compose run.
# Only set 0.0.0.0 yourself for a non-compose deployment AND only if you've added auth.
# DASHBOARD_HOST=0.0.0.0
