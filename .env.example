# Wallet that holds REPPO. Use a DEDICATED wallet, never your main one.
# Plaintext at rest — bounded by the budget caps in strategy.config.json.
REPPO_PRIVATE_KEY=

# Model-agnostic LLM. Set provider + that provider's key.
# provider: anthropic | openai | google | surplus
#   surplus = Surplus Intelligence (https://surplusintelligence.ai), an
#   OpenAI-compatible discounted-inference marketplace. Its API keys are
#   prefixed `inf_`; default model is claude-opus-4.8.
LLM_PROVIDER=surplus
LLM_API_KEY=inf_your_surplus_key

# Where strategy.config.json + ledgers live (mounted volume in Docker).
ORQUESTRA_DATA_DIR=./data
