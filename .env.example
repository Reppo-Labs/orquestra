# Wallet that holds REPPO. Use a DEDICATED wallet, never your main one.
# Plaintext at rest — bounded by the budget caps in strategy.config.json.
REPPO_PRIVATE_KEY=

# Reppo platform agent id, required to MINT pods (reppo >=0.8.0). OPTIONAL here:
# if minting is enabled and this is unset, the node auto-registers an agent on first
# run (`reppo register-agent`) and persists it to <data>/agent.json — set it explicitly
# only to reuse an existing agent identity.
# REPPO_AGENT_ID=

# Pinata IPFS JWT — REQUIRED to MINT (reppo pins each pod's dataset to IPFS via Pinata).
# Get one at https://pinata.cloud (free tier works). Only needed if you mint; voting
# does not require it. Operator-supplied — orquestra cannot provision it for you.
# PINATA_JWT=

# Model-agnostic LLM. Set provider + that provider's key.
# provider: anthropic | openai | google | surplus | virtuals
#   surplus = Surplus Intelligence (https://surplusintelligence.ai), an
#   OpenAI-compatible discounted-inference marketplace. Its API keys are
#   prefixed `inf_`; default model is claude-opus-4.8.
#   virtuals = Virtuals inference gateway (https://compute.virtuals.io), an
#   OpenAI-compatible endpoint (Bearer key) settled via the Agent Commerce
#   Protocol (no per-call USDC). Keys are prefixed `acp-`; default model
#   claude-opus-4-8 (list models at GET /v1/models).
LLM_PROVIDER=virtuals
LLM_API_KEY=acp_your_virtuals_key
# Onboarding is an LLM chat — an LLM key is REQUIRED to configure the node.

# Where strategy.config.json + ledgers live (mounted volume in Docker).
ORQUESTRA_DATA_DIR=./data

# Optional private Base RPC. The public default (https://mainnet.base.org) rate-limits
# under a full cycle of per-datanet queries, causing INTERNAL_ERROR skips. Set this to
# a private endpoint (Alchemy/QuickNode/Ankr/...) and every reppo CLI call uses it.
# RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Dashboard served inside the container — read + configure (onboarding, strategy).
# Unauthenticated by design; docker-compose.yml binds it to 127.0.0.1 only, reach it
# over an SSH tunnel (see README / ADR 0002). Do not expose the port without auth.
DASHBOARD_ENABLED=true
DASHBOARD_PORT=7070
